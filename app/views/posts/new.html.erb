<% content_for :title, "New Post" %>

<div class="w-full max-w-3xl mx-auto">
  <div class="mb-8">
    <h1 class="font-bold text-3xl text-gray-900">New Post</h1>
    <p class="mt-1 text-gray-500">Create a new blog post</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-8">
    <%= render "form", post: @post %>
  </div>

  <div class="mt-6">
    <%= link_to posts_path, class: "inline-flex items-center gap-2 rounded-lg px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
      </svg>
      Back to posts
    <% end %>
  </div>
</div>
