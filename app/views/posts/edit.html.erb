<% content_for :title, "Edit: #{@post.title}" %>

<div class="w-full max-w-3xl mx-auto">
  <div class="mb-8">
    <h1 class="font-bold text-3xl text-gray-900">Edit Post</h1>
    <p class="mt-1 text-gray-500">Editing "<%= @post.title %>"</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-8">
    <%= render "form", post: @post %>
  </div>

  <div class="flex items-center gap-3 mt-6">
    <%= link_to @post, class: "inline-flex items-center gap-2 rounded-lg px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
        <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
      </svg>
      View post
    <% end %>
    <%= link_to posts_path, class: "inline-flex items-center gap-2 rounded-lg px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
      </svg>
      Back to posts
    <% end %>
  </div>
</div>
