<% content_for :title, @post.title %>

<div class="w-full max-w-3xl mx-auto">
  <% if notice.present? %>
    <div class="mb-6 py-3 px-4 bg-green-50 border border-green-200 text-green-700 font-medium rounded-lg" id="notice">
      <%= notice %>
    </div>
  <% end %>

  <article class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="p-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-6"><%= @post.title %></h1>

      <%= render @post %>
    </div>
  </article>

  <div class="flex items-center gap-3 mt-6">
    <%= link_to edit_post_path(@post), class: "inline-flex items-center gap-2 rounded-lg px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
      </svg>
      Edit
    <% end %>
    <%= link_to posts_path, class: "inline-flex items-center gap-2 rounded-lg px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
      </svg>
      Back to posts
    <% end %>
    <%= button_to @post, method: :delete, form_class: "inline", class: "inline-flex items-center gap-2 rounded-lg px-4 py-2.5 bg-red-50 hover:bg-red-100 text-red-700 font-medium transition-colors", data: { turbo_confirm: "Are you sure you want to delete this post?" } do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
      </svg>
      Delete
    <% end %>
  </div>
</div>
